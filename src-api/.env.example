# Database Configuration
DATABASE_URL=postgresql://postgres:password@localhost:5432/professional_website_builder

# JWT Secret (change in production!)
JWT_SECRET=your-super-secret-jwt-key-change-this-in-production

# Encryption Key (must be 32 bytes, change in production!)
ENCRYPTION_KEY=your-32-byte-encryption-key-here!

# CORS Configuration
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# User Data Directory
USER_DATA_DIR=/app/user-data

# Project Root (for Next.js generation)
PROJECT_ROOT=/home/user/professional-website-builder

# Logging
RUST_LOG=professional_website_builder_api=debug,tower_http=debug
