# Professional Website Builder - Environment Variables
# Copy this file to .env and fill in your values

# ============================================================================
# Database Configuration
# ============================================================================
POSTGRES_DB=professional_website_builder
POSTGRES_USER=pwbuser
POSTGRES_PASSWORD=changeme_secure_password_here
POSTGRES_PORT=5432

# ============================================================================
# API Configuration
# ============================================================================
API_PORT=3001
RUST_LOG=info  # debug, info, warn, error

# Database connection string (automatically constructed from above)
DATABASE_URL=postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@postgres:5432/${POSTGRES_DB}

# ============================================================================
# Frontend Configuration
# ============================================================================
FRONTEND_PORT=80

# ============================================================================
# Generator Configuration
# ============================================================================
GENERATOR_PORT=3002

# ============================================================================
# LLM API Keys (Tier 2 - Cloud AI)
# ============================================================================
# Anthropic Claude API
ANTHROPIC_API_KEY=

# OpenAI GPT API
OPENAI_API_KEY=

# Google Gemini API
GEMINI_API_KEY=

# ============================================================================
# LLM Configuration (Tier 3 - Local AI)
# ============================================================================
# Ollama endpoint (if using local LLM)
OLLAMA_URL=http://ollama:11434

# LM Studio endpoint (alternative local LLM)
LMSTUDIO_URL=http://localhost:1234

# ============================================================================
# Security
# ============================================================================
# Secret key for encrypting sensitive data
SECRET_KEY=generate_a_secure_random_key_here

# JWT secret for authentication (future use)
JWT_SECRET=generate_another_secure_random_key_here

# CORS allowed origins (comma-separated)
CORS_ORIGINS=http://localhost:80,http://localhost:5173

# ============================================================================
# File Storage
# ============================================================================
# Maximum file upload size in MB
MAX_FILE_SIZE_MB=50

# Allowed file types (comma-separated)
ALLOWED_FILE_TYPES=.md,.docx,.pdf,.xlsx,.pptx

# ============================================================================
# Rate Limiting
# ============================================================================
# Requests per minute per IP
RATE_LIMIT_RPM=60

# ============================================================================
# Application Settings
# ============================================================================
# Environment: development, staging, production
NODE_ENV=production

# Enable debug mode
DEBUG=false

# Log level: debug, info, warn, error
LOG_LEVEL=info

# ============================================================================
# External Services
# ============================================================================
# Sentry DSN for error tracking (optional)
SENTRY_DSN=

# Analytics tracking ID (optional)
ANALYTICS_ID=

# ============================================================================
# Docker Development
# ============================================================================
# Set to 'true' for development mode with hot reload
DEV_MODE=false

# Expose database port in development
EXPOSE_DB_PORT=false
