<svg width="400" height="300" xmlns="http://www.w3.org/2000/svg">
  <rect width="400" height="300" fill="#FAFAFA"/>
  <rect width="400" height="50" fill="#FFFFFF"/>
  <text x="20" y="30" font-family="Arial, sans-serif" font-size="16" font-weight="bold" fill="#8B5CF6">Quartz</text>
  <rect x="20" y="70" width="360" height="200" fill="#FFFFFF" stroke="#E5E7EB" stroke-width="2" rx="8"/>
  <text x="40" y="100" font-family="Arial, sans-serif" font-size="14" fill="#1F2937">Light & Minimalist</text>
  <rect x="40" y="115" width="80" height="30" fill="#8B5CF6" rx="4"/>
  <text x="50" y="135" font-family="Arial, sans-serif" font-size="12" fill="#FFFFFF">Purple Accent</text>
  <line x1="40" y1="160" x2="200" y2="160" stroke="#E5E7EB" stroke-width="2"/>
  <line x1="40" y1="180" x2="180" y2="180" stroke="#E5E7EB" stroke-width="2"/>
  <line x1="40" y1="200" x2="220" y2="200" stroke="#E5E7EB" stroke-width="2"/>
</svg>
