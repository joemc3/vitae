{
  "name": "professional-website-builder",
  "version": "0.1.0",
  "private": true,
  "description": "A desktop application for generating professional portfolio websites from user documents",
  "workspaces": [
    "src-ui",
    "src-generator"
  ],
  "scripts": {
    "tauri": "tauri",
    "dev": "tauri dev",
    "build": "tauri build",
    "ui:dev": "npm run dev --workspace=src-ui",
    "generator:dev": "npm run dev --workspace=src-generator",
    "generator:build": "npm run build --workspace=src-generator",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\"",
    "format:check": "prettier --check \"**/*.{js,jsx,ts,tsx,json,css,scss,md}\""
  },
  "devDependencies": {
    "@tauri-apps/cli": "^1.5.9",
    "prettier": "^3.1.1"
  },
  "engines": {
    "node": ">=20.0.0",
    "npm": ">=10.0.0"
  }
}
